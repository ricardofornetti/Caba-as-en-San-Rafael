# =========================================================================
# SERVER-SIDE CONFIGURATION & SECRETS (Never prefix with VITE_, never use in client code)
# =========================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="https://your-app-url.run.app"

# PORT: The port the Express server binds to (should default to 3000)
PORT=3000

# NODE_ENV: Environment mode (development or production)
NODE_ENV="development"

# FIREBASE_PROJECT_ID: The project ID of your external Firebase project (Server-side)
FIREBASE_PROJECT_ID="your-firebase-project-id"

# FIREBASE_CLIENT_EMAIL: The client email of your Firebase service account.
FIREBASE_CLIENT_EMAIL="your-service-account-email@your-project-id.iam.gserviceaccount.com"

# FIREBASE_PRIVATE_KEY: The private key of your Firebase service account.
# Ensure that newlines (\n) are preserved or properly escaped.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"

# MP_ACCESS_TOKEN: Your private Mercado Pago access token (APP_USR-xxxx...)
MP_ACCESS_TOKEN="APP_USR-xxxx-xxxx-xxxx-xxxx"

# MP_WEBHOOK_SECRET: Secret key for validating Mercado Pago webhooks (x-signature check)
MP_WEBHOOK_SECRET="your_webhook_secret"

# ADMIN_EMAILS: Comma-separated list of whitelisted admin emails
ADMIN_EMAILS="fornettiricardo@gmail.com,email2@gmail.com"


# =========================================================================
# CLIENT-SIDE CONFIGURATION (Vite requires VITE_ prefix to expose these to the browser)
# =========================================================================

# NOTA IMPORTANTE: La variable VITE_FIREBASE_API_KEY NO es secreta por diseño
# en Firebase. Los clientes móviles y web la necesitan para identificar el proyecto.
# La seguridad se debe garantizar mediante Firebase Security Rules (firestore.rules),
# bloqueando accesos directos no autorizados.

VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-firebase-auth-domain"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
